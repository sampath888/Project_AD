# Environment
APP_NAME=PROJECT_AD
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://project_ad:project_ad_pass@localhost:5432/project_ad_db
DATABASE_URL_SYNC=postgresql://project_ad:project_ad_pass@localhost:5432/project_ad_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# File Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=ad-creatives

# Ad Platform API Keys
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

META_APP_ID=
META_APP_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

TWITTER_API_KEY=
TWITTER_API_SECRET=

# Email
SENDGRID_API_KEY=
FROM_EMAIL=noreply@projectad.com

# Admin defaults
ADMIN_EMAIL=admin@projectad.com
ADMIN_PASSWORD=admin123change_me
